<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <title>Lucrarea de laborator 3</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        form { max-width: 300px; padding: 15px; border: 1px solid #ccc; border-radius: 5px; }
        input, button { width: 93%; margin-top: 10px; padding: 8px; }
        #raspuns { margin-top: 15px; font-weight: bold; }
    </style>
</head>
<body>

    <form id="formularDate">
        <label for="nume">Nume:</label>
        <input type="text" id="nume" name="nume" required>
        
        <label for="varsta">Vârsta:</label>
        <input type="number" id="varsta" name="varsta" required>
        
        <button type="button" onclick="procesareFormular()">Afișează Rezultatul</button>
    </form>

    <div id="raspuns"></div>

    <script>
        function procesareFormular() {
            let nume = document.getElementById("nume").value;
            let varsta = document.getElementById("varsta").value;
            let raspuns = document.getElementById("raspuns");

            if (nume.trim() === "" || varsta.trim() === "") {
                raspuns.style.color = "red";
                raspuns.innerHTML = "Eroare: Vă rugăm să completați toate câmpurile.";
            } else {
                raspuns.style.color = "green";
                raspuns.innerHTML = "Date procesate cu succes! <br> Salut, " + nume + ". Ai " + varsta + " ani.";
            }
        }
    </script>

</body>
</html>

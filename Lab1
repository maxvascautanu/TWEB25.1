            notes: ""
        }, {
            no: 4,
            pos: "DF",
            nation: "AUT",
            player: "David Alaba",
            notes: ""
        }, {
            no: 5,
            pos: "MF",
            nation: "ENG",
            player: "Jude Bellingham",
            notes: ""
        }, {
            no: 6,
            pos: "MF",
            nation: "FRA",
            player: "Eduardo Camavinga",
            notes: ""
        }, {
            no: 7,

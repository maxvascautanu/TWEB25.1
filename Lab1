            notes: ""
        }, {
            no: 8,
            pos: "MF",
            nation: "URU",
            player: "Federico Valverde",
            notes: "Vice-captain"
        }, {
            no: 10,
            pos: "FW",
            nation: "FRA",
            player: "Kylian Mbappé",
            notes: ""
        }, {
            no: 11,
            pos: "FW",
            nation: "BRA",
            player: "Rodrygo",
            notes: ""
        }, {
            no: 12,
            pos: "DF",
            nation: "ENG",
            player: "Trent Alexander-Arnold",
            notes: ""
        }, {
            no: 13,
            pos: "GK",
            nation: "UKR",
            player: "Andriy Lunin",
            notes: ""
        }, {
            no: 14,
            pos: "MF",
            nation: "FRA",
            player: "Aurélien Tchouaméni",
            notes: ""
        }, {
            no: 15,
            pos: "MF",

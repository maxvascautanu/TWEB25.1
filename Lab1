<!doctype html>
<html lang="ro">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Real Madrid CF — Despre club</title>
    <style>
         :root {
            --bg: #0b1020;
            --panel: #0f1730;
            --card: #111a33;
            --text: #eef2ff;
            --muted: #b8c4ea;
            --gold: #d4af37;
            --line: rgba(255, 255, 255, .12);
            --shadow: 0 12px 30px rgba(0, 0, 0, .35);
            --r: 16px;
            --max: 1100px;
        }
        
        * {
            box-sizing: border-box
        }
        
        body {
            margin: 0;
            font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
            background: radial-gradient(1200px 600px at 10% 0%, #1a2a62 0%, var(--bg) 60%);
            color: var(--text);
        }
        
        a {
            color: inherit
        }
        
        .wrap {
            max-width: var(--max);
            margin: 0 auto;
            padding: 0 16px
        }
        
        header {
            position: sticky;
            top: 0;
            z-index: 10;
            backdrop-filter: blur(12px);
            background: rgba(10, 15, 30, .72);
            border-bottom: 1px solid var(--line);
        }
        
        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            padding: 12px 0
        }
        
        .brand {
            display: flex;
            gap: 10px;
            align-items: center
        }
        
        .logo {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: radial-gradient(circle at 30% 30%, #fff 0%, #f0f0f0 35%, #cfcfcf 75%);
            border: 1px solid rgba(255, 255, 255, .35);
            display: grid;
            place-items: center;
            font-weight: 900;
            color: #111;
        }
        
        nav {
            display: flex;
            gap: 10px;
            flex-wrap: wrap
        }
        
        nav a {
            text-decoration: none;
            padding: 8px 10px;
            border-radius: 12px;
            border: 1px solid transparent;
            color: var(--muted);
        }
        
        nav a:hover {
            border-color: var(--line);
            background: rgba(255, 255, 255, .06);
            color: var(--text)
        }
        
        .hero {
            padding: 18px 0 6px
        }
        
        .banner {
            border: 1px solid var(--line);
            border-radius: var(--r);
            background: radial-gradient(520px 260px at 18% 10%, rgba(212, 175, 55, .32), transparent 60%), radial-gradient(520px 260px at 86% 80%, rgba(120, 170, 255, .28), transparent 60%), linear-gradient(180deg, rgba(255, 255, 255, .08), rgba(255, 255, 255, .03));
            box-shadow: var(--shadow);
            overflow: hidden;
        }
        
        .bannerGrid {
            display: grid;
            grid-template-columns: 1.25fr .75fr;
            gap: 14px;
            padding: 16px
        }
        
        @media (max-width:900px) {
            .bannerGrid {
                grid-template-columns: 1fr
            }
        }
        
        h1 {
            margin: 0;
            font-size: clamp(22px, 3.2vw, 34px);
            line-height: 1.05
        }
        
        .muted {
            color: var(--muted)
        }
        
        .card {
            background: linear-gradient(180deg, rgba(255, 255, 255, .06), rgba(255, 255, 255, .03));
            border: 1px solid var(--line);
            border-radius: var(--r);
            box-shadow: var(--shadow);
            padding: 14px;
        }
        
        section {
            padding: 14px 0
        }
        
        .sectionTitle {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap;
            margin: 0 0 10px
        }
        
        .sectionTitle h2 {
            margin: 0;
            font-size: 20px
        }
        
        .grid2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px
        }
        
        @media (max-width:900px) {
            .grid2 {
                grid-template-columns: 1fr
            }
        }
        /* table */
        
        .controls {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 10px
        }
        
        .input {
            display: flex;
            gap: 10px;
            align-items: center;
            padding: 10px 12px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            min-width: 280px;
        }
        
        .input input {
            width: 100%;
            border: 0;
            outline: none;
            background: transparent;
            color: var(--text);
            font-size: 14px
        }
        
        select,
        button {
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .05);
            color: var(--text);
            padding: 10px 12px;
            border-radius: 14px;
            outline: none;
            font-weight: 700;
            cursor: pointer;
        }
        
        button:hover {
            background: rgba(255, 255, 255, .09)
        }
        
        option {
            color: #111
        }
        
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            overflow: hidden;
            border-radius: 14px;
            border: 1px solid var(--line)
        }
        
        thead th {
            text-align: left;
            background: rgba(255, 255, 255, .06);
            padding: 10px 10px;
            font-size: 13px;
            color: var(--muted);
            border-bottom: 1px solid var(--line);
        }
        
        tbody td {
            padding: 10px 10px;
            border-bottom: 1px solid rgba(255, 255, 255, .08);
            vertical-align: top;
            font-size: 14px;
        }
        
        tbody tr:hover {
            background: rgba(255, 255, 255, .04)
        }
        
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, .14);
            background: rgba(255, 255, 255, .04);
            color: var(--muted);
            font-size: 12px;
            margin-right: 6px;
        }
        
        .small {
            font-size: 12px;
            color: var(--muted)
        }
        
        footer {
            border-top: 1px solid var(--line);
            margin-top: 16px;
            padding: 16px 0 24px;
            color: var(--muted);
            text-align: center;
        }
    </style>
</head>

<body>
    <header>
        <div class="wrap">
            <div class="topbar">
                <div class="brand">
                    <div class="logo">RM</div>
                    <div>
                        <div style="font-weight:900">Real Madrid CF — Despre club</div>

                    </div>
                </div>
                <nav>
                    <a href="#overview">Prezentare</a>
                    <a href="#facts">Date cheie</a>
                    <a href="#honours">Palmares</a>
                    <a href="#squad">Lot (Current squad)</a>
                </nav>
            </div>
        </div>
    </header>

    <main class="wrap">
        <!-- HERO -->
        <section class="hero" id="overview">
            <div class="banner">
                <div class="bannerGrid">
                    <div>
                        <h1>Real Madrid Club de Fútbol</h1>
                        <p class="muted" style="margin:10px 0 0;max-width:70ch">
                            Pagina aceasta este un prototip „About / Club”, realizat exclusiv pe baza informațiilor din Wikipedia (Real Madrid CF) și include lotul din secțiunea “Current squad”.
                        </p>
                        <p class="small" style="margin:10px 0 0">
                            Sursă: Wikipedia — Real Madrid CF (secțiunea “Current squad”).
                        </p>
                    </div>
                    <div class="card">
                        <div style="font-weight:900;margin-bottom:8px">Nicknames (Wikipedia)</div>
                        <div class="badge">Los Blancos</div>
                        <div class="badge">Los Merengues</div>
                        <div class="badge">Los Vikingos</div>
                        <div class="badge">La Casa Blanca</div>
                        <div class="badge">Reyes de Europa</div>
                        <div class="badge">Madridistas (supporters)</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- KEY FACTS -->
        <section id="facts">
            <div class="sectionTitle">
                <h2>Date cheie</h2>
                <span class="muted">extras din infobox + introducere (Wikipedia)</span>
            </div>

            <div class="grid2">
                <div class="card">
                    <h3 style="margin:0 0 8px">Identitate</h3>
                    <p class="muted" style="margin:0;line-height:1.75">
                        <b>Denumire completă:</b> Real Madrid Club de Fútbol<br/>
                        <b>Fondat:</b> 6 March 1902 (as Madrid Football Club)<br/>
                        <b>Stadion:</b> Estadio Bernabéu<br/>
                        <b>Capacitate (infobox):</b> 83,186
                    </p>
                </div>

                <div class="card">
                    <h3 style="margin:0 0 8px">Notă despre lot</h3>
                    <p class="muted" style="margin:0;line-height:1.75">
                        În Wikipedia, secțiunea “Current squad” este marcată cu
                        <b>“As of 2 February 2026”</b>. În tabelul de mai jos, datele (număr, poziție, națională, jucător) sunt copiate din acea secțiune.
                    </p>
                </div>
            </div>
        </section>

        <!-- HONOURS (short, directly from intro line) -->
        <section id="honours">
            <div class="sectionTitle">
                <h2>Palmares (rezumat din Wikipedia)</h2>
                <span class="muted">trophies & records</span>
            </div>

            <div class="card">
                <p class="muted" style="margin:0;line-height:1.8">
                    <b>Domestic football:</b> 71 trophies, inclusiv record 36 La Liga titles, 20 Copa del Rey, 13 Supercopa de España (plus alte competiții menționate în Wikipedia).<br/>
                    <b>International football:</b> record 35 trophies, inclusiv record 15 European Cup/UEFA Champions League titles și record 6 UEFA Super Cups (plus alte competiții enumerate).
                </p>
                <p class="small" style="margin:10px 0 0">
                    (Text rezumat din propoziția de introducere a articolului Wikipedia.)
                </p>
            </div>
        </section>

        <!-- CURRENT SQUAD -->
        <section id="squad">
            <div class="sectionTitle">
                <h2>Lotul actual — Current squad</h2>
                <span class="muted">căutare + filtru + sortare (JS)</span>
            </div>

            <div class="controls">
                <div class="input" role="search">
                    🔎 <input id="q" type="text" placeholder="Caută jucător (ex: Bellingham, Mbappé)..." />
                </div>

                <label class="small" for="pos">Poziție:</label>
                <select id="pos">
        <option value="ALL">Toate</option>
        <option value="GK">GK</option>
        <option value="DF">DF</option>
        <option value="MF">MF</option>
        <option value="FW">FW</option>
      </select>

                <label class="small" for="sort">Sortează:</label>
                <select id="sort">
        <option value="NO_ASC">Număr ↑</option>
        <option value="NO_DESC">Număr ↓</option>
        <option value="NAME_ASC">Nume A–Z</option>
        <option value="NAME_DESC">Nume Z–A</option>
      </select>

                <button id="reset">Reset</button>
            </div>

            <div class="card" style="padding:12px">
                <div class="small" style="margin-bottom:10px">
                    Conform Wikipedia: <b>As of 2 February 2026</b> (Real Madrid CF — Current squad).
                </div>

                <table aria-label="Real Madrid current squad table">
                    <thead>
                        <tr>
                            <th style="width:70px">No.</th>
                            <th style="width:70px">Pos.</th>
                            <th style="width:90px">Nation</th>
                            <th>Player</th>
                            <th style="width:170px">Notes</th>
                        </tr>
                    </thead>
                    <tbody id="tbody"></tbody>
                </table>

                <div id="empty" class="small" style="display:none;margin-top:10px">
                    Nu există rezultate pentru filtrul curent.
                </div>
            </div>
        </section>

        <footer>
            © <span id="year"></span> — Prototip laborator.
        </footer>
    </main>

    <script>
        // ===== Data copied from Wikipedia (Real Madrid CF → “Current squad”, as of 2 February 2026) =====
        const squad = [{
            no: 1,
            pos: "GK",
            nation: "BEL",
            player: "Thibaut Courtois",
            notes: ""
        }, {
